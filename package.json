{
  "name": "kazan-event-radar",
  "version": "0.1.0",
  "description": "Telegram bot that monitors Kazan events, places, restaurants, viewpoints, and hidden gems from configured sources.",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "scan": "node src/scan.js",
    "browser": "powershell -ExecutionPolicy Bypass -File scripts/playwright-cli.ps1",
    "browser:help": "powershell -ExecutionPolicy Bypass -File scripts/playwright-cli.ps1 --help",
    "yandex:browser:open": "powershell -ExecutionPolicy Bypass -File scripts/playwright-cli.ps1 open https://afisha.yandex.ru/kazan --headed",
    "yandex:browser:state-save": "powershell -ExecutionPolicy Bypass -File scripts/playwright-cli.ps1 state-save data/playwright/yandex-state.json",
    "yandex:browser:sync": "node scripts/sync-yandex-browser-events.mjs",
    "yandex:browser:incremental": "node scripts/sync-yandex-browser-events.mjs --incremental",
    "yandex:browser:reconcile": "node scripts/sync-yandex-browser-events.mjs --reconcile --all",
    "mts:browser:open": "powershell -ExecutionPolicy Bypass -File scripts/playwright-cli.ps1 open https://live.mts.ru/kazan --headed",
    "mts:browser:state-save": "powershell -ExecutionPolicy Bypass -File scripts/playwright-cli.ps1 state-save data/playwright/mts-state.json",
    "mts:import": "node scripts/import-mts-live-events.mjs",
    "mts:incremental": "node scripts/import-mts-live-events.mjs --incremental",
    "mts:reconcile": "node scripts/import-mts-live-events.mjs --reconcile --all",
    "events:upload": "node scripts/upload-imported-events-via-kv.mjs",
    "events:upload:http": "node scripts/upload-imported-events.mjs",
    "events:upload:kv": "node scripts/upload-imported-events-via-kv.mjs",
    "kassir:browser:open": "powershell -ExecutionPolicy Bypass -File scripts/playwright-cli.ps1 open https://kzn.kassir.ru --headed",
    "kassir:browser:warmup": "node scripts/warmup-kassir-profile.mjs",
    "kassir:browser:state-save": "powershell -ExecutionPolicy Bypass -File scripts/playwright-cli.ps1 state-save data/playwright/kassir-state.json",
    "kassir:browser:sync": "node scripts/sync-kassir-browser-events.mjs",
    "kassir:browser:safe": "node scripts/sync-kassir-browser-events.mjs --incremental --max-links=20 --chunk-size=6 --pause-ms=1800 --retries=3",
    "kassir:browser:incremental": "node scripts/sync-kassir-browser-events.mjs --incremental",
    "kassir:browser:reconcile": "node scripts/sync-kassir-browser-events.mjs --reconcile --all",
    "afisha:browser:sync": "node scripts/sync-browser-events.mjs --skip-kassir",
    "afisha:browser:incremental": "node scripts/sync-browser-events.mjs --incremental --skip-kassir",
    "afisha:browser:reconcile": "node scripts/sync-browser-events.mjs --reconcile --all --skip-kassir",
    "afisha:browser:with-kassir": "node scripts/sync-browser-events.mjs --with-kassir",
    "afisha:browser:refresh": "node scripts/sync-browser-events.mjs --incremental --with-kassir --headless --kassir-headless --max-links=0 --chunk-size=6 --pause-ms=1800 --retries=3",
    "afisha:browser:year": "node scripts/sync-browser-events.mjs --incremental --with-kassir --headless --kassir-headless --max-links=0 --chunk-size=6 --pause-ms=1800 --retries=3",
    "catalog:sources": "node scripts/validate-catalog-sources.mjs",
    "catalog:build": "node scripts/build-catalog-import-overrides.mjs",
    "catalog:refresh": "node scripts/refresh-catalog-imports.mjs",
    "catalog:food": "node scripts/import-food-catalog.mjs",
    "catalog:sights": "node scripts/import-sights-catalog.mjs",
    "catalog:parks": "node scripts/import-parks-catalog.mjs",
    "catalog:hotels": "node scripts/import-hotels-catalog.mjs",
    "catalog:excursions": "node scripts/import-excursions-catalog.mjs",
    "catalog:routes": "node scripts/import-routes-catalog.mjs",
    "catalog:active": "node scripts/import-active-catalog.mjs",
    "catalog:roadtrip": "node scripts/import-roadtrip-catalog.mjs",
    "set-token": "powershell -ExecutionPolicy Bypass -File scripts/set-telegram-token.ps1",
    "set-analytics-password": "powershell -ExecutionPolicy Bypass -File scripts/set-analytics-password.ps1",
    "worker:whoami": "npx wrangler whoami --config worker/wrangler.toml --env-file .cloudflare.env",
    "worker:kv:create": "npx wrangler kv namespace create KAZAN_KV --config worker/wrangler.toml --env-file .cloudflare.env",
    "worker:kv:create:preview": "npx wrangler kv namespace create KAZAN_KV --preview --config worker/wrangler.toml --env-file .cloudflare.env",
    "worker:dev": "npx wrangler dev --config worker/wrangler.toml --env-file .cloudflare.env",
    "worker:deploy": "npx wrangler deploy --config worker/wrangler.toml --env-file .cloudflare.env",
    "worker:set-webhook": "node worker/scripts/set-webhook.js",
    "worker:set-miniapp-api": "node worker/scripts/set-miniapp-api.js",
    "check": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"Get-ChildItem src,public,worker,scripts -Recurse -Include *.js,*.mjs | ForEach-Object { node --check $_.FullName }\""
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "node-cron": "^3.0.3",
    "pino": "^9.6.0",
    "playwright-core": "^1.59.1",
    "rss-parser": "^3.13.0",
    "telegraf": "^4.16.3"
  },
  "engines": {
    "node": ">=20"
  }
}
